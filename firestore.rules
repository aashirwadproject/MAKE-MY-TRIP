rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: trips
    // Fields: id, name, status, date, activities[], userId, createdAt
    //
    // Collection: expenses
    // Fields: id, description, amount, category, member, userId, createdAt
    //
    // Collection: members
    // Fields: name, userId
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidTrip(data) {
      return data.keys().hasAll(['id', 'name', 'status', 'userId']) &&
             data.id is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.status in ['ongoing', 'previous'] &&
             data.userId == request.auth.uid;
    }

    function isValidExpense(data) {
      return data.keys().hasAll(['id', 'description', 'amount', 'userId']) &&
             data.id is string &&
             data.description is string && data.description.size() > 0 && data.description.size() < 200 &&
             data.amount is number &&
             data.userId == request.auth.uid;
    }

    function isValidMember(data) {
      return data.keys().hasAll(['name', 'userId']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 50 &&
             data.userId == request.auth.uid;
    }

    match /trips/{tripId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isValidTrip(request.resource.data);
      allow update: if isDocOwner() && isValidTrip(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /expenses/{expenseId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isValidExpense(request.resource.data);
      allow update: if isDocOwner() && isValidExpense(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /members/{memberId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isValidMember(request.resource.data);
      allow update: if isDocOwner() && isValidMember(request.resource.data);
      allow delete: if isDocOwner();
    }
  }
}
