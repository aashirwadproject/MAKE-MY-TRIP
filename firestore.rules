rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: trips
    // Fields: id, name, status, date, activities[], userId, createdAt
    //
    // Collection: expenses
    // Fields: id, description, amount, category, member, userId, createdAt
    //
    // Collection: members
    // Fields: name, userId
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "dikshaaashirwad@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidTrip(data) {
      return data.keys().hasAll(['id', 'name', 'status', 'userId']) &&
             data.id is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.status in ['ongoing', 'previous'] &&
             data.userId == request.auth.uid;
    }

    function isValidExpense(data) {
      return data.keys().hasAll(['id', 'description', 'amount', 'userId']) &&
             data.id is string &&
             data.description is string && data.description.size() > 0 && data.description.size() < 200 &&
             data.amount is number &&
             data.userId == request.auth.uid;
    }

    function isValidMember(data) {
      return data.keys().hasAll(['name', 'userId']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 50 &&
             data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.role == 'user';
      allow update: if isAdmin(); // Only admins can change roles
    }

    match /trips/{tripId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated() && isValidTrip(request.resource.data);
      allow update: if (isDocOwner() || isAdmin()) && isValidTrip(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }

    match /expenses/{expenseId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated() && isValidExpense(request.resource.data);
      allow update: if (isDocOwner() || isAdmin()) && isValidExpense(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }

    match /members/{memberId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated() && isValidMember(request.resource.data);
      allow update: if (isDocOwner() || isAdmin()) && isValidMember(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }
  }
}
